{
    admin off
}

# HTTP 端口 80
:80 {
    encode gzip zstd
    
    # 安全头
    header {Request-Context} ""
    header -Server
    
    # API 路由 - 编排器
    handle /api/* {
        reverse_proxy orchestrator:8001 {
            header_up Host {upstream_hostport}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
    
    # 健康检查
    handle /health {
        respond "OK" 200
    }
    
    # Web 控制台 - Laravel
    handle /* {
        reverse_proxy console:8000 {
            header_up Host {upstream_hostport}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
}

# Grafana（observability profile）
grafana.xiaozhou.dev {
    encode gzip
    reverse_proxy grafana:3000
}

# Prometheus（observability profile）
metrics.xiaozhou.dev {
    encode gzip
    reverse_proxy prometheus:9090
}

{
    admin off
}

# 绑定域名并启用你提供的证书（方案 18.2：Caddy 反代 + 自动 HTTPS）
# 证书放置于仓库 certs/（已 gitignore，绝不入库），容器挂载为 /certs
xiaozhou.qtechvending.com {
    encode gzip

    # 编排器 API（控制台只发任务，Loop 在 orchestrator）
    # 注意：用 handle（保留 /api 前缀），不要用 handle_path（会剥离前缀导致 404）
    handle /api/* {
        reverse_proxy orchestrator:8001
    }

    # Web 控制台（Laravel/Livewire/FluxUI）
    reverse_proxy console:8000

    # 使用提供的证书（完整链 + 私钥）；Caddy 不再走 ACME
    tls /certs/xiaozhou.qtechvending.com_bundle.pem /certs/xiaozhou.qtechvending.com.key
}

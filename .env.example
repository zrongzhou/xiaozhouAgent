# =====================================================================
# xiaozhouAgent 环境变量样例（复制为 .env 后填写真实值，.env 不入库）
# 密钥注入遵循方案第十五章：密文只进 .env / docker secrets，绝不进 git
# =====================================================================

# ---- 基础 ----
TZ=Asia/Shanghai
APP_NAME=xiaozhouAgent
APP_ENV=production
APP_DEBUG=false
APP_KEY=                      # 部署时由 `php artisan key:generate` 生成
APP_URL_HOST=43.152.232.197   # 访问域名或 IP；有域名时改为域名并启用 Caddy HTTPS

DATA_DIR=/data

# ---- 控制台（Laravel）----
CONSOLE_PORT=8000

# ---- 编排器（Python）----
ORCHESTRATOR_PORT=8001

# ---- PostgreSQL ----
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=xiaozhou
DB_USERNAME=xiaozhou
DB_PASSWORD=                  # 必填，部署脚本会随机生成

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- MinIO（对象存储，profile: storage 启用）----
MINIO_ROOT_USER=              # 必填
MINIO_ROOT_PASSWORD=          # 必填，>=8 位
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=projects

# ---- 模型路由器（方案第十/十一章）----
# 手工指定模型示例见 config/model-profiles.yaml；此处为默认主脑
DEFAULT_MODEL_PROVIDER=openai
DEFAULT_MODEL=glm-4-plus
DEFAULT_MODEL_BASE_URL=https://open.bigmodel.cn/api/paip/v4
DEFAULT_MODEL_API_KEY=        # 商业 API Key（必填）

# 可选：轻量自托管/备用模型（路由/格式化用）
LIGHT_MODEL_PROVIDER=
LIGHT_MODEL=
LIGHT_MODEL_BASE_URL=
LIGHT_MODEL_API_KEY=

# ---- GitHub（Agent 读取/推送仓库用，可选）----
GITHUB_TOKEN=

# ---- Caddy ----
# 留空则仅 HTTP(:80)；填入域名后启用自动 HTTPS
CADDY_DOMAIN=

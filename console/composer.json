{
    "name": "zrongzhou/xiaozhou-console",
    "type": "project",
    "description": "xiaozhouAgent Web 控制台（Laravel + Livewire + FluxUI 就绪）",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "livewire/livewire": "^3.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
        "post-update-cmd": "php artisan optimize:clear"
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {}
    },
    "policy": {
        "advisories": {
            "block": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
